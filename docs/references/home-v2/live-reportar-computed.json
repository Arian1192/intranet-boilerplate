  "dialogHTML": "<div id=\"modal-incidencia\" class=\"w-[min(30rem,calc(100vw-2rem))] overflow-hidden rounded-xl border border-slate-200 bg-white shadow-2xl\"><div class=\"flex items-center justify-between border-b border-slate-100 px-4 py-3\"><h3 class=\"text-sm font-semibold text-slate-800\">Reportar</h3><div class=\"flex h-7 items-center rounded-lg border border-slate-200 p-0.5\"><button class=\"rounded-md px-2 py-0.5 text-xs font-medium transition bg-slate-100 text-slate-800\">Algo falla</button><button class=\"rounded-md px-2 py-0.5 text-xs font-medium transition text-slate-400 hover:text-slate-700\">Una idea</button></div></div><div class=\"space-y-3 p-4\"><textarea class=\"input min-h-[90px] text-sm\" placeholder=\"Qué esperabas que pasara y qué ha pasado…\" style=\"\"></textarea><button class=\"flex w-full items-center justify-center gap-2 rounded-lg border border-dashed border-slate-300 py-2.5 text-xs font-medium text-slate-500 transition hover:border-slate-400 hover:text-slate-700\">Añadir captura<span class=\"text-slate-300\">·</span><span class=\"font-normal text-slate-400\">o pega una con ⌘V</span></button><p class=\"text-[11px] leading-relaxed text-slate-400\">Se adjuntan solos la página, el navegador, el tamaño de ventana y los últimos errores.</p></div><div class=\"flex justify-end gap-2 border-t border-slate-100 bg-slate-50 px-4 py-3\"><button class=\"btn-ghost text-sm\">Cancelar</button><button disabled=\"\" class=\"btn-primary text-sm disabled:opacity-40\">Enviar</button></div></div>"
